# Database (Prisma schema uses MySQL)
# Vercel: use hosted MySQL (PlanetScale, Railway, Aiven, RDS, etc.) — Vercel does not provide MySQL.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

# NextAuth — required on Vercel or /api/auth/csrf returns 500 and login breaks
AUTH_SECRET="your-auth-secret-here-min-32-chars-long"
AUTH_TRUST_HOST="true"
# Vercel: must match your real public URL (no trailing slash)
# AUTH_URL="https://your-project.vercel.app"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Vercel: same as AUTH_URL (no trailing slash)
NEXT_PUBLIC_APP_NAME="Click Track Marketing — Feedback Tool"
NEXT_PUBLIC_BRAND_NAME="Click Track Marketing"

# Storage
STORAGE_TYPE="local"
UPLOAD_DIR="./public/uploads"
# For future S3-compatible storage:
# STORAGE_TYPE="s3"
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Click Track Marketing <noreply@clicktrackmarketing.com>"

# Security
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# Development
NODE_ENV="development"
