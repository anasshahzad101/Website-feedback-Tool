# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/speedx_feedback?schema=public"

# NextAuth
AUTH_SECRET="your-auth-secret-here-min-32-chars-long"
AUTH_TRUST_HOST="true"
# Production behind reverse proxy: set to your public URL so login redirects and cookies work (e.g. https://yourdomain.com)
# AUTH_URL="https://yourdomain.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Click Track Marketing — Feedback Tool"
NEXT_PUBLIC_BRAND_NAME="Click Track Marketing"

# Storage
STORAGE_TYPE="local"
UPLOAD_DIR="./public/uploads"
# For future S3-compatible storage:
# STORAGE_TYPE="s3"
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Click Track Marketing <noreply@clicktrackmarketing.com>"

# Screenshot/Puppeteer (for website captures)
PUPPETEER_EXECUTABLE_PATH=""

# Security
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# Development
NODE_ENV="development"
