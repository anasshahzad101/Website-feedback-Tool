# Database
# Local dev without MySQL: use SQLite (prisma/dev.db)
USE_SQLITE=true
# Production / Vercel: set USE_SQLITE=false (or remove) and use MySQL — e.g. PlanetScale, Railway, Aiven, RDS.
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

# NextAuth — required on Vercel or /api/auth/csrf returns 500 and login breaks
AUTH_SECRET="your-auth-secret-here-min-32-chars-long"
AUTH_TRUST_HOST="true"
# Vercel: must match your real public URL (no trailing slash)
# AUTH_URL="https://your-project.vercel.app"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Vercel: same as AUTH_URL (no trailing slash)
NEXT_PUBLIC_APP_NAME="Website Feedback Tool"
NEXT_PUBLIC_BRAND_NAME="Website Feedback Tool"

# Storage
STORAGE_TYPE="local"
UPLOAD_DIR="./public/uploads"
# For future S3-compatible storage:
# STORAGE_TYPE="s3"
# S3_ENDPOINT=""
# S3_REGION=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# ScreenshotOne (OPTIONAL — only needed for snapshot fallback + pin thumbnails)
# Live website mode works fully without this. Without a key:
#  - The "Save snapshot" button reports as not-configured
#  - Comment threads omit the small context thumbnail in the sidebar
# Sign up at https://screenshotone.com — free tier: 100 screenshots/mo.
# SCREENSHOTONE_ACCESS_KEY=""

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Website Feedback Tool <noreply@example.com>"

# Security
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# Development
NODE_ENV="development"

# Hostinger / production checklist (fill a copy — see hostinger.env.template in repo root)
