{
  "name": "speedx-feedback-tool",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate.mjs && next build",
    "start": "next start -p ${PORT:-3002}",
    "postinstall": "node scripts/prisma-generate.mjs",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:local:generate": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:local:migrate": "prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "db:local:push": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:local:seed": "tsx prisma/seed.ts",
    "db:local:setup": "npm run db:local:generate && npm run db:local:push && npm run db:local:seed",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
